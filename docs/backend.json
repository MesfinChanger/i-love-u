
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "I Love U app profile restricted to 18+. Includes relationship constraints, verified location tracking, and mandatory tax info for commercial users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "publicNickname": { "type": "string" },
        "birthdate": { "type": "string", "format": "date" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string" },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "address1": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "postalCode": { "type": "string" },
        "taxId": { "type": "string" },
        "isSeller": { "type": "boolean", "default": false },
        "isAdvertiser": { "type": "boolean", "default": false },
        "isAdmin": { "type": "boolean", "default": false },
        "isHuman": { "type": "boolean", "default": true },
        "role": { "type": "string", "default": "member", "description": "Unified authority field. 'admin' grants platform power." },
        "sellerStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "advertiserStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "policyAccepted": { "type": "boolean", "default": false },
        "idleTimeout": { "type": "number", "default": 300 }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A spark connection between two hearts.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["spark", "friend"] },
        "status": { "type": "string" },
        "lastMessage": { "type": "string" },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A secured E2EE message within a conversation.",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "encryptedText": { "type": "string" },
        "iv": { "type": "string" },
        "text": { "type": "string", "description": "Fallback for unencrypted or system messages" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles" },
    "/publicProfiles/{userId}": { "schema": "UserProfile", "description": "Discovery data" },
    "/conversations/{conversationId}": { "schema": "Conversation", "description": "Unified connections" },
    "/messages/{messageId}": { "schema": "Message", "description": "Global message registry" },
    "/ideaPool/{postId}": { "description": "Global knowledge pool" },
    "/siteSettings/{settingId}": { "description": "Global platform settings including sovereignty" }
  }
}
