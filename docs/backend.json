
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Dating app profile restricted to 18+. Includes relationship constraints and verified location tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "culturalInterests": { "type": "array", "items": { "type": "string" } },
        "languagesLearning": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "location": { "type": "string" },
        "country": { "type": "string", "description": "ISO 3166-1 alpha-2 country code" },
        "relationshipStatus": { "type": "string", "enum": ["single", "dating"] },
        "isSeller": { "type": "boolean", "default": false },
        "isAdvertiser": { "type": "boolean", "default": false },
        "isLocalProducer": { "type": "boolean", "default": false },
        "isNewEntrepreneur": { "type": "boolean", "default": false },
        "negotiationRequested": { "type": "boolean", "default": false },
        "subscriptionType": { "type": "string", "enum": ["free", "basic_seller", "pro_seller"], "default": "free" },
        "publicKey": { "type": "string" },
        "currency": { "type": "string", "default": "USD" }
      },
      "required": ["uid", "displayName", "age", "gender"]
    },
    "Match": {
      "title": "Match",
      "description": "Connection between users.",
      "type": "object",
      "properties": {
        "userIds": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "unmatched"] },
        "type": { "type": "string", "enum": ["friend", "date"], "default": "friend" },
        "witnessId": { "type": "string", "description": "The UID of the user invited to witness the relationship" },
        "witnessStatus": { "type": "string", "enum": ["none", "pending", "confirmed"], "default": "none" }
      }
    },
    "AdCampaign": {
      "title": "Ad Campaign",
      "description": "A paid advertisement shown in the discover feed, supporting text or video.",
      "type": "object",
      "properties": {
        "advertiserId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "adType": { "type": "string", "enum": ["text", "video"], "default": "text" },
        "videoUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetUrl": { "type": "string" },
        "targetCountries": { "type": "array", "items": { "type": "string" }, "description": "List of country codes where this ad is legal and targeted." },
        "isGloballyLegal": { "type": "boolean", "default": true },
        "budget": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "paused"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Donation": {
      "title": "Donation",
      "description": "A voluntary contribution to support the 100% free community.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number", "minimum": 1 },
        "currency": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Shop": {
      "title": "Shop",
      "description": "A seller's virtual store for gifting items.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["Flowers", "Jewelry", "Electronics", "Apparel", "Home"] }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Items available for purchase as gifts.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Gift": {
      "title": "Gift",
      "description": "A purchased item sent to a match.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "productId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "delivered"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat message with gift attachment support.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "encryptedText": { "type": "string" },
        "giftId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/donations/{donationId}": { "schema": "Donation", "description": "Support donations" },
    "/shops/{shopId}": { "schema": "Shop", "description": "Seller shops" },
    "/shops/{shopId}/products/{productId}": { "schema": "Product", "description": "Shop inventory" },
    "/matches/{matchId}": { "schema": "Match", "description": "Active connections" },
    "/matches/{matchId}/messages/{messageId}": { "schema": "Message", "description": "Moderated chat history" },
    "/users/{userId}/receivedGifts/{giftId}": { "schema": "Gift", "description": "User gift history" },
    "/ads/{adId}": { "schema": "AdCampaign", "description": "Sponsored discovery ads" }
  }
}
