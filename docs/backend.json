
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Unified heart identity and personality schema. Restricted to 18+.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": ["string", "null"] },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "accountType": { "type": "string", "enum": ["guest", "free", "premium", "business"] },
        "status": { "type": "string", "enum": ["active", "blocked", "deleted"] },
        "bio": { "type": "string" },
        "birthday": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "location": { "type": "object" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "interests": { "type": "array", "items": { "type": "string" } },
        "profession": { "type": "string" },
        "education": { "type": "string" },
        "hobbies": { "type": "array", "items": { "type": "string" } },
        "values": { "type": "array", "items": { "type": "string" } },
        "privacySettings": { "type": "object" },
        "role": { "type": "string", "default": "member" },
        "policyAccepted": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A spark connection between two hearts.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["spark", "friend"] },
        "status": { "type": "string" },
        "lastMessage": { "type": "string" },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A secured E2EE message within a conversation.",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "encryptedText": { "type": "string" },
        "iv": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles" },
    "/publicProfiles/{userId}": { "schema": "UserProfile", "description": "Discovery data" },
    "/conversations/{conversationId}": { "schema": "Conversation", "description": "Unified connections" },
    "/messages/{messageId}": { "schema": "Message", "description": "Global message registry" },
    "/communityMessages/{messageId}": { "description": "Global Wall messages" },
    "/ideaPool/{postId}": { "description": "Global knowledge pool" },
    "/siteSettings/{settingId}": { "description": "Global platform settings" }
  }
}
