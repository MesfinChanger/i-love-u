
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "I Love U app profile restricted to 18+. Includes relationship constraints, verified location tracking, and mandatory tax info for commercial users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "birthdate": { "type": "string", "format": "date" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "culturalInterests": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "additionalPhotoUrls": { "type": "array", "items": { "type": "string" } },
        "address1": { "type": "string" },
        "address2": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string", "description": "ISO 3166-1 alpha-2 country code" },
        "taxId": { "type": "string", "description": "SSN or TIN. Strictly protected and used for payment verification." },
        "relationshipStatus": { "type": "string", "enum": ["single", "dating"] },
        "isSeller": { "type": "boolean", "default": false },
        "isAdvertiser": { "type": "boolean", "default": false },
        "publicKey": { "type": "string" },
        "currency": { "type": "string", "default": "USD" },
        "publicNickname": { "type": "string" },
        "isPhotoPublic": { "type": "boolean", "default": false },
        "isAgeVerified": { "type": "boolean", "default": false },
        "isRespectful": { "type": "boolean", "default": false },
        "isHuman": { "type": "boolean", "default": false }
      },
      "required": ["uid", "firstName", "lastName", "birthdate"]
    },
    "PublicProfile": {
      "title": "Public Profile",
      "description": "Minimal discovery data visible to everyone. Hides identifying info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "locationHint": { "type": "string" },
        "publicNickname": { "type": "string" },
        "publicPhotoUrl": { "type": "string" },
        "additionalPhotoUrls": { "type": "array", "items": { "type": "string" } },
        "country": { "type": "string" },
        "birthMonthDay": { "type": "string", "description": "Month and Day of birth only for privacy." }
      }
    },
    "Match": {
      "title": "Match",
      "description": "Heart connection between users using a deterministic ID for security verification.",
      "type": "object",
      "properties": {
        "userIds": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "unmatched", "declined"] },
        "type": { "type": "string", "enum": ["friend", "date"], "default": "friend" },
        "invitedBy": { "type": "string" },
        "witnessId": { "type": "string" },
        "witnessStatus": { "type": "string", "enum": ["none", "pending", "confirmed"] }
      }
    },
    "AdCampaign": {
      "title": "Ad Campaign",
      "description": "A paid advertisement shown in the discovery feed, supporting text or video.",
      "type": "object",
      "properties": {
        "advertiserId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "adType": { "type": "string", "enum": ["text", "video"], "default": "text" },
        "targetCountries": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "paused"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Donation": {
      "title": "Donation",
      "description": "A voluntary contribution to support the 100% free I Love U community.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number", "minimum": 1 },
        "currency": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat message with gift, file, and translation support.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "encryptedText": { "type": "string" },
        "translatedText": { "type": "string" },
        "giftId": { "type": "string" },
        "giftImageUrl": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "fileSize": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isSensitive": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "CommunityMessage": {
      "title": "Community Message",
      "description": "A public message shared on the global community wall. Strictly moderated.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderNickname": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "isSensitive": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Gift Product",
      "description": "Item available in the marketplace.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles" },
    "/publicProfiles/{userId}": { "schema": "PublicProfile", "description": "Minimal discovery data" },
    "/donations/{donationId}": { "schema": "Donation", "description": "Support donations" },
    "/matches/{matchId}": { "schema": "Match", "description": "Active connections" },
    "/matches/{matchId}/messages/{messageId}": { "schema": "Message", "description": "Moderated chat history" },
    "/ads/{adId}": { "schema": "AdCampaign", "description": "Sponsored discovery ads" },
    "/communityMessages/{messageId}": { "schema": "CommunityMessage", "description": "Global moderated feed" },
    "/global_products/{productId}": { "schema": "Product", "description": "Gift inventory" },
    "/shops/{shopId}": { "schema": "object", "description": "Seller storefronts" },
    "/config/pricing": { "schema": "object", "description": "Global price settings" }
  }
}
