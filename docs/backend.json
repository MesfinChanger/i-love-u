
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Unified heart identity, personality, and discovery schema. Restricted to 18+.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": ["string", "null"] },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "accountType": { "type": "string", "enum": ["guest", "free", "premium", "business"] },
        "status": { "type": "string", "enum": ["active", "blocked", "deleted"] },
        "bio": { "type": "string" },
        "birthday": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "location": { "type": "object" },
        "languages": { "type": "array", "items": { "type": "string" } },
        "interests": { "type": "array", "items": { "type": "string" } },
        "profession": { "type": "string" },
        "education": { "type": "string" },
        "hobbies": { "type": "array", "items": { "type": "string" } },
        "values": { "type": "array", "items": { "type": "string" } },
        "datingGoal": { "type": "string", "enum": ["serious", "friendship", "marriage", "exploring"] },
        "preferredAgeRange": { "type": "string" },
        "preferredCountries": { "type": "array", "items": { "type": "string" } },
        "personalityTags": { "type": "array", "items": { "type": "string" } },
        "verified": { "type": "boolean", "default": false },
        "visibility": { "type": "string", "enum": ["public", "private", "hidden"] },
        "privacySettings": { "type": "object" },
        "role": { "type": "string", "default": "member" },
        "policyAccepted": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "PublicKey": {
      "title": "Public Key",
      "description": "E2EE Identity Key used for secured heart-to-heart agreement.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "publicKey": { "type": "string" },
        "algorithm": { "type": "string", "default": "ECDH-P256" },
        "createdAt": { "type": "string", "format": "date-time" },
        "rotatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A secured chat room for high-fidelity communication between hearts.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["spark", "circle", "shopping", "idea"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "encryptionVersion": { "type": "string", "default": "v1" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A secured, encrypted message packet.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "encryptedText": { "type": "string" },
        "encryptedMedia": { "type": "array", "items": { "type": "string" } },
        "iv": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
        "conversationId": { "type": "string" }
      }
    },
    "Shop": {
      "title": "Shop",
      "description": "A verified seller storefront in the prosperity marketplace.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" },
        "country": { "type": "string" },
        "rating": { "type": "number", "default": 0 },
        "verified": { "type": "boolean", "default": false }
      }
    },
    "Product": {
      "title": "Product",
      "description": "A specific item for sale by a verified shop.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string" },
        "inventory": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A recorded transaction between a buyer and an artisan.",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "products": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "shippingStatus": { "type": "string", "enum": ["pending", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Connection": {
      "title": "Connection",
      "description": "An invitation or established match between two hearts.",
      "type": "object",
      "properties": {
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "matched"] }
      }
    },
    "Relationship": {
      "title": "Relationship",
      "description": "Established friend status or block protocol between two hearts.",
      "type": "object",
      "properties": {
        "userA": { "type": "string" },
        "userB": { "type": "string" },
        "status": { "type": "string", "enum": ["friends", "blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Circle": {
      "title": "Community Circle",
      "description": "A gathering space for hearts sharing a specific vibration.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "imageURL": { "type": "string" },
        "memberCount": { "type": "number", "default": 1 },
        "privacy": { "type": "string", "enum": ["open", "private"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PoolPost": {
      "title": "Pool Post",
      "description": "A mission-driven thought shared in the global Prosperity Pool.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "category": { "type": "string", "enum": ["economics", "technology", "politics", "philosophy", "general"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "media": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number", "default": 0 },
        "commentsCount": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CommunityMessage": {
      "title": "Community Message",
      "description": "A public thought shared on the Global Wall.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "A system or interaction alert for a specific heart.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["message", "like", "match", "order", "idea"] },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles" },
    "/users/{userId}/notifications/{notificationId}": { "schema": "Notification", "description": "Private user alerts" },
    "/publicProfiles/{userId}": { "schema": "UserProfile", "description": "Discovery data" },
    "/publicKeys/{userId}": { "schema": "PublicKey", "description": "E2EE identity keys" },
    "/connections/{connectionId}": { "schema": "Connection", "description": "Match and Invitation registry" },
    "/conversations/{conversationId}": { "schema": "Conversation", "description": "High-fidelity chat rooms" },
    "/messages/{messageId}": { "schema": "Message", "description": "High-fidelity secured messages" },
    "/relationships/{relationshipId}": { "schema": "Relationship", "description": "Friend states and community blocking." },
    "/communityMessages/{messageId}": { "schema": "CommunityMessage", "description": "Global Wall messages" },
    "/ideaPool/{postId}": { "schema": "PoolPost", "description": "Global knowledge pool" },
    "/circles/{circleId}": { "schema": "Circle", "description": "Global community circles registry" },
    "/shops/{shopId}": { "schema": "Shop", "description": "Verified seller storefronts" },
    "/products/{productId}": { "schema": "Product", "description": "Artisan products listed by verified shops" },
    "/orders/{orderId}": { "schema": "Order", "description": "Marketplace transaction ledger" },
    "/siteSettings/{settingId}": { "description": "Global platform settings" }
  }
}
