
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Dating app profile restricted to 18+. Includes relationship constraints and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "location": { "type": "string" },
        "preferredLanguage": { "type": "string", "default": "English" },
        "relationshipStatus": { "type": "string", "enum": ["single", "dating"], "default": "single" },
        "partnerId": { "type": "string", "description": "UID of current dating partner." },
        "isSupporter": { "type": "boolean", "default": false, "description": "Whether the user has donated to support the app." },
        "settings": {
          "type": "object",
          "properties": {
            "allowSensitiveContent": { "type": "boolean", "default": false }
          }
        },
        "preferences": {
          "type": "object",
          "properties": {
            "preferredAgeRanges": { 
              "type": "array", 
              "items": { "type": "string", "enum": ["18-33", "34-49", "50-65", "66+"] }
            }
          }
        }
      },
      "required": ["uid", "displayName", "age", "gender"]
    },
    "Match": {
      "title": "Match",
      "description": "Connection between users.",
      "type": "object",
      "properties": {
        "userIds": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "unmatched"] },
        "type": { "type": "string", "enum": ["friend", "date"], "default": "friend" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat message with AI moderation fields.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isSensitive": { "type": "boolean", "default": false },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles with strict 18+ enforcement."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Active connections."
    },
    "/matches/{matchId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Moderated chat history."
    }
  }
}
