
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Detailed profile information for a dating app user. Restricted to ages 18 and over.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "preferredLanguage": { "type": "string", "description": "The user's preferred language (e.g., 'English', 'Spanish', 'French')." },
        "relationshipStatus": { "type": "string", "enum": ["single", "dating"], "default": "single" },
        "partnerId": { "type": "string", "description": "UID of the current dating partner." },
        "settings": {
          "type": "object",
          "properties": {
            "allowSensitiveContent": { "type": "boolean", "default": false, "description": "Whether the user allows receiving explicit or sensitive images." }
          }
        },
        "preferences": {
          "type": "object",
          "properties": {
            "lookingFor": { "type": "string" },
            "minAge": { "type": "number", "minimum": 18 },
            "maxAge": { "type": "number" }
          }
        }
      },
      "required": ["uid", "displayName", "age", "photoUrl"]
    },
    "Match": {
      "title": "Match",
      "description": "Represents a successful connection between two users.",
      "type": "object",
      "properties": {
        "userIds": { "array": { "items": { "type": "string" } } },
        "timestamp": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "unmatched"] },
        "type": { "type": "string", "enum": ["friend", "date"], "default": "friend" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single chat message between users.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isSensitive": { "type": "boolean", "default": false },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Public and private user profile data."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Connections between users."
    },
    "/matches/{matchId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat history for a specific match."
    }
  }
}
