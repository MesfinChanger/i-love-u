
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Unified heart identity and personality schema.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "accountType": { "type": "string", "enum": ["guest", "free", "premium", "business"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "displayName", "interests", "accountType"]
    },
    "Product": {
      "title": "Marketplace Product",
      "description": "Artisan listing for prosperity exchange.",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "inventory": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "images": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["sellerId", "name", "price", "status"]
    },
    "SparkGreeting": {
      "title": "Community Greeting",
      "description": "Initial respectful outreach between hearts.",
      "type": "object",
      "properties": {
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "read", "replied", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUserId", "toUserId", "message", "status", "createdAt"]
    },
    "CircleMessage": {
      "title": "Circle Community Message",
      "description": "Shared discourse record within a community circle.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "edited": { "type": "boolean" },
        "deleted": { "type": "boolean" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private heart identities" },
    "/products/{productId}": { "schema": "Product", "description": "Marketplace artisan listings" },
    "/sparkProfiles/{userId}": { "schema": "UserProfile", "description": "Public discovery profiles" },
    "/sparkGreetings/{greetingId}": { "schema": "SparkGreeting", "description": "Community outreach interactions" },
    "/conversations/{conversationId}": { "schema": "Conversation", "description": "Secured private interaction spaces" },
    "/communities/{circleId}/messages/{messageId}": { "schema": "CircleMessage", "description": "Community circle group chat messages" }
  }
}
