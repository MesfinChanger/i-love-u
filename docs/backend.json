
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Unified heart identity and personality schema.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "accountType": { "type": "string", "enum": ["guest", "free", "premium", "business"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "displayName", "interests", "accountType"]
    },
    "SparkProfile": {
      "title": "Spark Profile",
      "description": "Discovery and matching schema for romantic and cultural sparks.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "relationshipGoal": { "type": "string", "enum": ["friendship", "dating", "serious", "marriage"] },
        "preferredCountries": { "type": "array", "items": { "type": "string" } },
        "verified": { "type": "boolean" },
        "visibility": { "type": "string", "enum": ["public", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "age", "gender", "country", "relationshipGoal"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Private heart alert.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["message", "like", "match", "order", "idea"] },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "body", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private heart identities" },
    "/sparkProfiles/{userId}": { "schema": "SparkProfile", "description": "Public discovery profiles" },
    "/users/{userId}/notifications/{notificationId}": { "schema": "Notification", "description": "User alerts" }
  }
}
