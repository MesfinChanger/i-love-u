
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "I Love U app profile restricted to 18+. Includes relationship constraints, verified location tracking, and mandatory tax info for commercial users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "name": { "type": "string", "description": "Legacy field for name sync." },
        "birthdate": { "type": "string", "format": "date" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "address1": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "postalCode": { "type": "string" },
        "taxId": { "type": "string" },
        "isSeller": { "type": "boolean", "default": false },
        "isAdvertiser": { "type": "boolean", "default": false },
        "isAdmin": { "type": "boolean", "default": false },
        "role": { "type": "string", "description": "Sovereign-assigned role (e.g. member, admin).", "default": "member" },
        "sellerStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "advertiserStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "policyAccepted": { "type": "boolean", "default": false },
        "idleTimeout": { "type": "number", "description": "Idle timeout in seconds before auto-logout.", "default": 300 }
      }
    },
    "IdeaPoolPost": {
      "title": "Idea Pool Post",
      "description": "A public thought or idea shared in the global swimming pool of knowledge.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "authorName": { "type": "string" },
        "topic": { "type": "string", "enum": ["Economy", "Politics", "Science", "Technology", "Philosophy", "General"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Ad": {
      "title": "Advertisement",
      "description": "Premium community advertisement campaign.",
      "type": "object",
      "properties": {
        "advertiserId": { "type": "string" },
        "adType": { "type": "string", "enum": ["text", "video"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "rejected"] },
        "budget": { "type": "number" },
        "targetCountries": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles" },
    "/publicProfiles/{userId}": { "schema": "UserProfile", "description": "Discovery data" },
    "/matches/{matchId}": { "description": "Connections" },
    "/ideaPool/{postId}": { "schema": "IdeaPoolPost", "description": "Global knowledge pool" },
    "/siteSettings/{settingId}": { "description": "Global platform settings including sovereignty" },
    "/ads/{adId}": { "schema": "Ad", "description": "Ad campaigns" }
  }
}
