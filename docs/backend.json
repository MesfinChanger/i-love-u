{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Unified heart identity and personality schema.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "accountType": { "type": "string", "enum": ["guest", "free", "premium", "business"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "displayName", "interests", "accountType"]
    },
    "SparkProfile": {
      "title": "Spark Profile",
      "description": "Discovery and matching schema for romantic and cultural sparks.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "relationshipGoal": { "type": "string", "enum": ["friendship", "dating", "serious", "marriage"] },
        "preferredCountries": { "type": "array", "items": { "type": "string" } },
        "verified": { "type": "boolean" },
        "visibility": { "type": "string", "enum": ["public", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "age", "gender", "country", "relationshipGoal"]
    },
    "SparkLike": {
      "title": "Spark Like",
      "description": "A heart-to-heart connection attempt.",
      "type": "object",
      "properties": {
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUserId", "toUserId", "status", "createdAt"]
    },
    "Match": {
      "title": "Match",
      "description": "An established connection between two hearts.",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["users", "status", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A shared communication channel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["spark", "circle-private", "circle-group", "shopping", "idea"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "title": { "type": "string" },
        "imageURL": { "type": "string" },
        "encryptionVersion": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A secured piece of communication.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "encryptedText": { "type": "string" },
        "iv": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "voice", "file"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] }
      }
    },
    "Circle": {
      "title": "Community Circle",
      "description": "A community gathering space.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Technology", "Business", "Education", "Travel", "Culture", "Sports", "Music", "Environment", "General"] },
        "imageURL": { "type": "string" },
        "ownerId": { "type": "string" },
        "privacy": { "type": "string", "enum": ["open", "private"] },
        "memberCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "privacy", "memberCount"]
    },
    "CircleMember": {
      "title": "Circle Member",
      "description": "A heart participating in a community gathering.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "member"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private heart identities" },
    "/sparkProfiles/{userId}": { "schema": "SparkProfile", "description": "Public discovery profiles" },
    "/sparkLikes/{likeId}": { "schema": "SparkLike", "description": "Connection attempts registry" },
    "/matches/{matchId}": { "schema": "Match", "description": "Established high-fidelity connections" },
    "/friendships/{friendshipId}": { "schema": "Friendship", "description": "Cultural bridge registry" },
    "/communities/{communityId}": { "schema": "Circle", "description": "Community gatherings" },
    "/communities/{communityId}/members/{memberId}": { "schema": "CircleMember", "description": "Circle participant registry" },
    "/conversations/{convId}": { "schema": "Conversation", "description": "Secured communication channels" },
    "/messages/{msgId}": { "schema": "Message", "description": "Secured high-fidelity messages" }
  }
}
