
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "I Love U app profile restricted to 18+. Includes relationship constraints, verified location tracking, and mandatory tax info for commercial users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "culturalInterests": { "type": "array", "items": { "type": "string" } },
        "languagesLearning": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string", "description": "Full physical address for commercial compliance." },
        "taxId": { "type": "string", "description": "SSN or TIN. Strictly protected and used for payment verification." },
        "country": { "type": "string", "description": "ISO 3166-1 alpha-2 country code" },
        "relationshipStatus": { "type": "string", "enum": ["single", "dating"] },
        "isSeller": { "type": "boolean", "default": false },
        "isAdvertiser": { "type": "boolean", "default": false },
        "publicKey": { "type": "string" },
        "currency": { "type": "string", "default": "USD" },
        "settings": {
          "type": "object",
          "properties": {
            "allowSensitiveContent": { "type": "boolean", "default": false }
          }
        }
      },
      "required": ["uid", "displayName", "age", "gender"]
    },
    "PublicProfile": {
      "title": "Public Profile",
      "description": "Minimal discovery data visible to everyone. Hides identifying info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "culturalInterests": { "type": "array", "items": { "type": "string" } },
        "locationHint": { "type": "string" }
      }
    },
    "Match": {
      "title": "Match",
      "description": "Heart connection between users using a deterministic ID for security verification.",
      "type": "object",
      "properties": {
        "userIds": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "unmatched"] },
        "type": { "type": "string", "enum": ["friend", "date"], "default": "friend" },
        "witnessId": { "type": "string" },
        "witnessStatus": { "type": "string", "enum": ["none", "pending", "confirmed"] }
      }
    },
    "AdCampaign": {
      "title": "Ad Campaign",
      "description": "A paid advertisement shown in the discovery feed, supporting text or video.",
      "type": "object",
      "properties": {
        "advertiserId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "adType": { "type": "string", "enum": ["text", "video"], "default": "text" },
        "targetCountries": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "paused"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Donation": {
      "title": "Donation",
      "description": "A voluntary contribution to support the 100% free I Love U community.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number", "minimum": 1 },
        "currency": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Chat message with gift attachment support.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "encryptedText": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles" },
    "/publicProfiles/{userId}": { "schema": "PublicProfile", "description": "Minimal discovery data" },
    "/donations/{donationId}": { "schema": "Donation", "description": "Support donations" },
    "/matches/{matchId}": { "schema": "Match", "description": "Active connections" },
    "/matches/{matchId}/messages/{messageId}": { "schema": "Message", "description": "Moderated chat history" },
    "/ads/{adId}": { "schema": "AdCampaign", "description": "Sponsored discovery ads" }
  }
}
