
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Unified heart identity and personality schema.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "accountType": { "type": "string", "enum": ["guest", "free", "premium", "business"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "displayName", "interests", "accountType"]
    },
    "PrivacySettings": {
      "title": "Privacy Settings",
      "description": "User-specific visibility and interaction control registry.",
      "type": "object",
      "properties": {
        "showOnlineStatus": { "type": "boolean" },
        "allowSparkMessages": { "type": "boolean" },
        "allowCircleMessages": { "type": "boolean" },
        "allowShoppingMessages": { "type": "boolean" },
        "showLocation": { "type": "boolean" },
        "showEmail": { "type": "boolean" },
        "showPhone": { "type": "boolean" }
      }
    },
    "DeviceSession": {
      "title": "Device Session",
      "description": "Registered heartbeat of a device used by a heart.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "deviceName": { "type": "string" },
        "deviceType": { "type": "string", "enum": ["web", "android", "ios"] },
        "browser": { "type": "string" },
        "ipAddress": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "trusted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SecurityEvent": {
      "title": "Security Event",
      "description": "Audit log for identity protection.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["login", "logout", "password_change", "device_added", "suspicious_activity"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TrustScore": {
      "title": "Trust Score",
      "description": "Reputation and verification metrics for a heart.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "verifiedEmail": { "type": "boolean" },
        "verifiedPhone": { "type": "boolean" },
        "verifiedIdentity": { "type": "boolean" },
        "positiveReviews": { "type": "number" },
        "reports": { "type": "number" }
      },
      "required": ["userId", "score"]
    },
    "Wallet": {
      "title": "Heart Wallet",
      "description": "Prosperity registry for store balances and mission funding.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "currency": { "type": "string" },
        "availableBalance": { "type": "number" },
        "pendingBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "locked", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "currency", "availableBalance", "status"]
    },
    "Transaction": {
      "title": "Prosperity Transaction",
      "description": "Financial heartbeat of a heart's prosperity journey.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "walletId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "purchase", "refund", "transfer", "donation", "subscription"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed", "cancelled"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["walletId", "userId", "type", "amount", "currency", "status"]
    },
    "Block": {
      "title": "User Block",
      "description": "A record of a heart maintaining its sacred space.",
      "type": "object",
      "properties": {
        "blockerId": { "type": "string" },
        "blockedUserId": { "type": "string" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["blockerId", "blockedUserId", "createdAt"]
    },
    "Report": {
      "title": "Community Report",
      "description": "Accountability registry for respectful behavior enforcement.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reportedUserId": { "type": "string" },
        "reason": { "type": "string", "enum": ["spam", "harassment", "fake_account", "fraud"] },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "reportedUserId", "reason", "createdAt"]
    },
    "SparkProfile": {
      "title": "Spark Profile",
      "description": "Discovery and matching schema for romantic and cultural sparks.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "relationshipGoal": { "type": "string", "enum": ["friendship", "dating", "serious", "marriage"] },
        "preferredCountries": { "type": "array", "items": { "type": "string" } },
        "verified": { "type": "boolean" },
        "visibility": { "type": "string", "enum": ["public", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "age", "gender", "country", "relationshipGoal"]
    },
    "Match": {
      "title": "Match",
      "description": "An established connection between two hearts.",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["users", "status", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A shared communication channel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["spark", "circle-private", "circle-group", "shopping", "idea"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "title": { "type": "string" },
        "imageURL": { "type": "string" },
        "encryptionVersion": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A secured piece of communication.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "encryptedText": { "type": "string" },
        "iv": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "voice", "file"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] }
      }
    },
    "Store": {
      "title": "Artisan Store",
      "description": "A verified shop in the local community.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoURL": { "type": "string" },
        "country": { "type": "string" },
        "category": { "type": "string" },
        "verified": { "type": "boolean" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Shop Product",
      "description": "An item for sale in the marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "category": { "type": "string" },
        "inventory": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Marketplace Order",
      "description": "A recorded purchase transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "products": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "currency": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "shippingStatus": { "type": "string", "enum": ["processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Organization": {
      "title": "Community Organization",
      "description": "Registered entities within the Prosperity Revolution.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["company", "school", "government", "ngo", "church", "hospital", "community"] },
        "logo": { "type": "string" },
        "website": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "timezone": { "type": "string" },
        "ownerId": { "type": "string" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "type", "ownerId"]
    },
    "OrganizationMember": {
      "title": "Organization Member",
      "description": "Affiliated heart within a community entity.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "department": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "joinedAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private heart identities" },
    "/users/{userId}/settings/privacy": { "schema": "PrivacySettings", "description": "User visibility and interaction control" },
    "/users/{userId}/sessions/{sessionId}": { "schema": "DeviceSession", "description": "Registered device heartbeats" },
    "/users/{userId}/securityEvents/{eventId}": { "schema": "SecurityEvent", "description": "Identity protection audit logs" },
    "/devices/{deviceId}": { "schema": "DeviceSession", "description": "Global device registry" },
    "/trustScores/{userId}": { "schema": "TrustScore", "description": "High-fidelity reputation registry" },
    "/wallets/{userId}": { "schema": "Wallet", "description": "Prosperity registries for hearts" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Prosperity transaction logs (Global Protocol)" },
    "/blocks/{blockId}": { "schema": "Block", "description": "Community safety registry" },
    "/reports/{reportId}": { "schema": "Report", "description": "Accountability and moderation registry" },
    "/sparkProfiles/{userId}": { "schema": "SparkProfile", "description": "Public discovery profiles" },
    "/matches/{matchId}": { "schema": "Match", "description": "Established high-fidelity connections" },
    "/conversations/{convId}": { "schema": "Conversation", "description": "Secured communication channels" },
    "/conversations/{convId}/messages/{msgId}": { "schema": "Message", "description": "Secured high-fidelity subcollection messages" },
    "/shops/{shopId}": { "schema": "Store", "description": "Verified local artisan shops" },
    "/products/{productId}": { "schema": "Product", "description": "Marketplace product listings" },
    "/orders/{orderId}": { "schema": "Order", "description": "Recorded purchase transactions" },
    "/organizations/{orgId}": { "schema": "Organization", "description": "Global community organization registry" },
    "/organizations/{orgId}/members/{memberId}": { "schema": "OrganizationMember", "description": "High-Fidelity organization membership registry" }
  }
}
