
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "I Love U app profile restricted to 18+. Includes relationship constraints, verified location tracking, and mandatory tax info for commercial users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "displayName": { "type": "string" },
        "birthdate": { "type": "string", "format": "date" },
        "age": { "type": "number", "minimum": 18 },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "religion": { "type": "string" },
        "bio": { "type": "string" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "address1": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "taxId": { "type": "string" },
        "isSeller": { "type": "boolean", "default": false },
        "isAdvertiser": { "type": "boolean", "default": false },
        "sellerStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "advertiserStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "isAdmin": { "type": "boolean", "default": false },
        "policyAccepted": { "type": "boolean", "default": false }
      }
    },
    "Ad": {
      "title": "Advertisement",
      "description": "Premium community advertisement campaign.",
      "type": "object",
      "properties": {
        "advertiserId": { "type": "string" },
        "adType": { "type": "string", "enum": ["text", "video"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "rejected"] },
        "budget": { "type": "number" },
        "targetCountries": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Shop": {
      "title": "Seller Shop",
      "description": "Virtual storefront for verified artisans.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "phone", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles" },
    "/publicProfiles/{userId}": { "schema": "PublicProfile", "description": "Discovery data" },
    "/matches/{matchId}": { "schema": "Match", "description": "Connections" },
    "/ads/{adId}": { "schema": "Ad", "description": "Ad campaigns" },
    "/shops/{shopId}": { "schema": "Shop", "description": "Seller storefronts" },
    "/global_products/{productId}": { "description": "Marketplace inventory" }
  }
}
