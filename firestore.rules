rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // ============================
    // MISSION HELPERS
    // ============================
    
    function signedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return signedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        request.auth.token.email == "thearmyoj@gmail.com"
      );
    }
    
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isModerator() {
      return signedIn()
      &&
      (
        userRole() == "moderator"
        ||
        isAdmin()
      );
    }

    function isGuest() {
      return signedIn()
      &&
      userRole() == "guest";
    }

    function isMember() {
      return signedIn()
      &&
      userRole() != "guest";
    }

    // ============================
    // USER PROFILES & PRIVATE DATA
    // ============================

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      allow create: 
        if request.auth.uid == userId
        && request.resource.data.role != "admin";
      
      allow update:
        if
          (
            request.auth.uid == userId
            &&
            request.resource.data.role == resource.data.role
            &&
            request.resource.data.accountType == resource.data.accountType
            &&
            request.resource.data.status == resource.data.status
          )
          ||
          isAdmin();

      allow delete:
        if request.auth.uid == userId || isAdmin();
    }

    match /wallets/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /transactions/{txId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.buyerId;
    }

    // ============================
    // SPARK ❤️ (Dating)
    // ============================

    match /sparkProfiles/{userId} {
      allow read: if request.auth != null && (resource.data.visibility == "public" || request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /publicProfiles/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /sparkGreetings/{greetingId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUserId;
      allow read: if request.auth != null && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == resource.data.toUserId || isAdmin());
    }

    match /connections/{connectionId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId || isAdmin());
      allow create, update: if request.auth != null;
    }

    match /relationships/{relId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userA || request.auth.uid == resource.data.userB || isAdmin());
      allow create, update: if request.auth != null;
    }

    /*
     CONVERSATIONS / PRIVATE MESSAGES
    */

    match /conversations/{conversationId} {

      // Users can only open conversations they belong to
      allow read:
        if signedIn()
        &&
        request.auth.uid in resource.data.participants;

      // Create conversation only if creator is a participant
      allow create:
        if signedIn()
        &&
        request.auth.uid in request.resource.data.participants;

      // Conversation changes only by participants
      allow update:
        if signedIn()
        &&
        request.auth.uid in resource.data.participants;

      // Never delete conversations directly
      allow delete:
        if false;

      /*
       PRIVATE CHAT MESSAGES
      */

      match /messages/{messageId} {

        // Read only by conversation members
        allow read:
          if signedIn()
          &&
          request.auth.uid in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participants;

        // Send only as yourself AND if you are a participant
        allow create:
          if signedIn()
          &&
          request.auth.uid == request.resource.data.senderId
          &&
          request.auth.uid in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participants;

        // Sender can edit own message
        allow update:
          if signedIn()
          &&
          request.auth.uid == resource.data.senderId;

        // Block direct deletion
        allow delete:
          if false;
      }
    }

    /*
     PRODUCTS / MARKETPLACE
    */

    match /products/{productId} {

      allow read:
        if true;

      allow create:
        if signedIn()
        &&
        (
          userRole()=="verified"
          ||
          userRole()=="merchant"
          ||
          isAdmin()
        );

      allow delete:
        if isModerator();
    }

    // ============================
    // COMMUNITIES & IDEAS
    // ============================

    match /communities/{communityId} {

      // Guests and members may discover communities
      allow read:
        if signedIn();

      // Creating communities requires a real member
      allow create:
        if isMember();

      allow update, delete:
        if signedIn()
        &&
        (
          request.auth.uid == resource.data.ownerId
          ||
          isAdmin()
        );


      match /members/{memberId} {

        allow read:
          if signedIn();

        // Guest cannot join communities
        allow create, update:
          if isMember()
          &&
          request.auth.uid == memberId;
      }
    }


    match /communityMessages/{msgId} {

      // Guest can read community discussions
      allow read:
        if signedIn();

      // Only members can post
      allow create:
        if isMember()
        &&
        request.auth.uid == request.resource.data.authorId;
    }


    match /communityMedia/{mediaId} {

      // Guest can view approved media
      allow read:
        if signedIn();

      // Upload requires membership
      allow create:
        if isMember()
        &&
        request.auth.uid == request.resource.data.authorId;
    }


    match /ideaPool/{ideaId} {

      // Discovery allowed
      allow read:
        if signedIn();

      // Publishing ideas requires membership
      allow create:
        if isMember()
        &&
        request.auth.uid == request.resource.data.authorId;
    }


    // ============================
    // COMMERCE & ADS
    // ============================

    match /shops/{shopId} {

      // Guests may browse shops
      allow read:
        if signedIn();

      // Only members can create/update shops
      allow create, update:
        if isMember()
        &&
        (
          request.auth.uid == resource.data.ownerId
          ||
          isAdmin()
        );
    }


    match /ads/{adId} {

      // Approved ads are visible
      allow read:
        if signedIn()
        &&
        (
          resource.data.status == "approved"
          ||
          request.auth.uid == resource.data.advertiserId
          ||
          isAdmin()
        );


      // Only members advertise
      allow create:
        if isMember()
        &&
        request.auth.uid == request.resource.data.advertiserId;


      allow update, delete:
        if signedIn()
        &&
        (
          request.auth.uid == resource.data.advertiserId
          ||
          isAdmin()
        );
    }

    // ============================
    // SYSTEM & MAINTENANCE
    // ============================

    match /siteSettings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    match /publicKeys/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /guestSessions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /securityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false; // Only written via server protocol
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}