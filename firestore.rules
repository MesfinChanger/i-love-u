
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if a match exists between two users using a deterministic ID
    function hasActiveMatch(uid1, uid2) {
      let matchId = uid1 < uid2 ? uid1 + "_" + uid2 : uid2 + "_" + uid1;
      return exists(/databases/$(database)/documents/matches/$(matchId)) && 
             get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'active';
    }

    function isParticipant(matchId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
    }

    // User Profiles - Strict privacy
    match /users/{userId} {
      // Only the owner can see everything (TaxID, address, etc)
      // Only a matched partner can see the profile (Age, Gender, Bio, Photo)
      allow read: if isOwner(userId) || (isAuthenticated() && hasActiveMatch(request.auth.uid, userId));
      allow write: if isOwner(userId);
    }

    // Discovery Profiles - Minimal info for everyone
    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Advertisements - Only creator can manage
    match /ads/{adId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.advertiserId == request.auth.uid;
    }

    // Donations - Private history
    match /donations/{donationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Matches & E2EE Messages - Immutable for safety
    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds;
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.userIds || request.auth.uid == resource.data.witnessId);
      allow delete: if false; 

      match /messages/{messageId} {
        allow read: if isParticipant(matchId);
        allow create: if isParticipant(matchId);
        allow update, delete: if false; // IMMUTABLE FOR ACCOUNTABILITY
      }
    }

    // Reports - Admin only read
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}
