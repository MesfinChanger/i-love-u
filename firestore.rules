
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(matchId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
    }

    // User Profiles
    match /users/{userId} {
      // Public profiles can be read by any member
      allow read: if isAuthenticated();
      // Only the owner can update their own profile
      allow write: if isOwner(userId);
      
      // Sensitive private data (like exact location or keys) should be in a subcollection
      match /private/{document} {
        allow read, write: if isOwner(userId);
      }
    }

    // Advertisements
    match /ads/{adId} {
      // Everyone can see ads in the feed
      allow read: if isAuthenticated();
      // Only the advertiser can create or manage their own ads
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.advertiserId == request.auth.uid;
    }

    // Donations
    match /donations/{donationId} {
      // Only the donor can see their own donation record
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Only the system/auth user can create a donation record
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Shops & Products
    match /shops/{shopId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;

      match /products/{productId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId;
      }
    }

    // Matches & E2EE Messages
    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      // Matches are permanent for accountability
      allow delete: if false; 

      match /messages/{messageId} {
        // Only participants can read the message sub-collection
        allow read: if isParticipant(matchId);
        // Messages are immutable: allow creation but strictly forbid updates or individual deletions
        allow create: if isParticipant(matchId);
        allow update, delete: if false;
      }
    }

    // Safety Reports
    match /reports/{reportId} {
      // Any authenticated user can file a safety report
      allow create: if isAuthenticated();
      // Only admins can read reports (handled by false for public access)
      allow read, update, delete: if false;
    }
    
    // Witness System
    match /witness_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.witnessId || request.auth.uid == resource.data.requesterId);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.witnessId;
    }
  }
}
