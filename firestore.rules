
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      
      match /notifications/{id} { allow read, write: if isOwner(userId); }
    }

    match /publicProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /relationships/{id} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.userA || request.auth.uid == resource.data.userB || request.auth.uid == request.resource.data.userA || request.auth.uid == request.resource.data.userB);
    }

    match /circles/{id} {
      allow read: if true;
      allow write: if isAuthenticated() && (isOwner(request.resource.data.ownerId) || isOwner(resource.data.ownerId));
    }

    match /ideaPool/{id} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
      allow update, delete: if isAuthenticated() && isOwner(resource.data.authorId);
    }

    match /communityMessages/{id} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.authorId);
    }

    match /shops/{id} {
      allow read: if true;
      allow write: if isAuthenticated() && isOwner(request.resource.data.ownerId);
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAuthenticated() && isOwner(request.resource.data.storeId);
    }

    match /orders/{id} {
      allow read: if isAuthenticated() && (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.buyerId);
    }

    match /conversations/{id} {
      allow read, write: if isAuthenticated() && (request.auth.uid in resource.data.participants || request.auth.uid in request.resource.data.participants);
    }

    match /messages/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /publicKeys/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
  }
}
