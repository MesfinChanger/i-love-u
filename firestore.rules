
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Private heart identities
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;

      // High-Fidelity Security Registry
      match /sessions/{sessionId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /securityEvents/{eventId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
      }
    }

    // Global Device Registry
    match /devices/{deviceId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // High-Fidelity Trust Registry
    match /trustScores/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // System managed reputation
    }

    // Public discovery profiles
    match /sparkProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Established high-fidelity connections
    match /matches/{matchId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null;
    }

    // High-Fidelity Chat Protocol
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && (
        (request.method == 'create') || 
        (request.auth.uid in resource.data.participants)
      );

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Artisan Marketplace Protocol
    match /shops/{shopId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.ownerId;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.storeId;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
      allow create: if request.auth != null;
    }
  }
}
