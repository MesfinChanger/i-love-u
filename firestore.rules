
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Private heart identities
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;

      // Privacy Protocol Registry
      match /settings/privacy {
        allow read, write: if request.auth.uid == userId;
      }

      // High-Fidelity Security Registry
      match /sessions/{sessionId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /securityEvents/{eventId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
      }
    }

    // Global Device Registry
    match /devices/{deviceId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // High-Fidelity Trust Registry
    match /trustScores/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // System managed reputation
    }

    // High-Fidelity Wallet Registry
    match /wallets/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    // Prosperity Transaction Registry (Flat Protocol)
    match /transactions/{transactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Global Payment Bridge Registry
    match /payments/{paymentId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    // Formal Prosperity Receipt Registry
    match /receipts/{receiptId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.sellerId
      );
      allow create: if false; // System generated only via Admin protocol
    }

    // High-Fidelity Financial Audit Registry
    match /auditLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // High-Fidelity Analytics Protocol
    match /analyticsEvents/{eventId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Community Safety Registry
    match /blocks/{blockId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.blockerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.blockerId;
    }

    // Accountability & Moderation Registry
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false; // Only accessible to system administrators
    }

    // Public discovery profiles
    match /sparkProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Established high-fidelity connections
    match /matches/{matchId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null;
    }

    // High-Fidelity Chat Protocol
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && (
        (request.method == 'create') || 
        (request.auth.uid in resource.data.participants)
      );

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Artisan Marketplace Protocol
    match /shops/{shopId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.ownerId;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.storeId;
    }

    match /objects/{objectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId);
      allow create: if request.auth != null;
    }

    // Organization Registry Protocol
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.ownerId;

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId;
      }
    }

    // Global Regional Configuration Registry
    match /countries/{countryCode} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Research Registry Protocol
    match /researchers/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    match /researchProjects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.ownerId || 
        request.auth.uid in resource.data.teamMembers
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      match /experiments/{experimentId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/researchProjects/$(projectId)).data.ownerId || 
          request.auth.uid in get(/databases/$(database)/documents/researchProjects/$(projectId)).data.teamMembers
        );
      }
    }
  }
}
