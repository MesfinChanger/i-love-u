
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasAcceptedPolicy() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.policyAccepted == true;
    }

    // Helper to check if a match (any status) exists between two users
    function hasAnyMatch(uid1, uid2) {
      let matchId = uid1 < uid2 ? uid1 + "_" + uid2 : uid2 + "_" + uid1;
      return exists(/databases/$(database)/documents/matches/$(matchId));
    }

    function isParticipant(matchId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
    }

    function isWitness(matchId) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/matches/$(matchId)).data.witnessId;
    }

    // User Profiles - Strict privacy but allow viewing participants/witnesses
    match /users/{userId} {
      allow read: if isOwner(userId) || (isAuthenticated() && (hasAnyMatch(request.auth.uid, userId)));
      // Allow write if owner. If it's a critical change, we could restrict it further.
      allow write: if isOwner(userId);
    }

    // Discovery Profiles - Minimal info for everyone
    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && hasAcceptedPolicy();
    }

    // Advertisements - Only creator can manage
    match /ads/{adId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid && hasAcceptedPolicy();
      allow update, delete: if isAuthenticated() && resource.data.advertiserId == request.auth.uid;
    }

    // Donations - Private history
    match /donations/{donationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Matches & E2EE Messages - Immutable for safety
    match /matches/{matchId} {
      allow get: if isAuthenticated() && (request.auth.uid in resource.data.userIds || request.auth.uid == resource.data.witnessId);
      allow list: if isAuthenticated() && (request.auth.uid in resource.data.userIds);
      allow list: if isAuthenticated() && (request.auth.uid == resource.data.witnessId);
      
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds && hasAcceptedPolicy();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.userIds || request.auth.uid == resource.data.witnessId);
      allow delete: if false; 

      match /messages/{messageId} {
        allow read: if isParticipant(matchId);
        allow create: if isParticipant(matchId) && hasAcceptedPolicy();
        allow update, delete: if false; 
      }
    }

    // Community Wall - Public moderated feed
    match /communityMessages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid && hasAcceptedPolicy();
      allow update, delete: if false;
    }

    // Global Collections
    match /global_products/{productId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /shops/{shopId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.resource.data.ownerId == request.auth.uid || resource.data.ownerId == request.auth.uid) && hasAcceptedPolicy();
    }

    match /config/pricing {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Reports - Admin only read
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}
