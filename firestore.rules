rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // User profiles: Only the owner can write; anyone authenticated can read
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Matches: Users can read/write if they are part of the match
    match /matches/{matchId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds;

      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
      }
    }
  }
}