
rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // ============================
    // MISSION HELPERS
    // ============================
    
    function signedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return signedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        request.auth.token.email == "thearmyoj@gmail.com"
      );
    }
    
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isModerator() {
      return signedIn()
      &&
      (
        userRole() == "moderator"
        ||
        isAdmin()
      );
    }

    function isGuest() {
      return signedIn()
      &&
      userRole() == "guest";
    }

    function isMember() {
      return signedIn()
      &&
      userRole() != "guest";
    }

    // ============================
    // USER PROFILES & PRIVATE DATA
    // ============================

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      allow create: 
        if request.auth.uid == userId
        && request.resource.data.role != "admin";
      
      allow update:
        if
          (
            request.auth.uid == userId
            &&
            request.resource.data.role == resource.data.role
            &&
            request.resource.data.accountType == resource.data.accountType
            &&
            request.resource.data.status == resource.data.status
          )
          ||
          isAdmin();

      allow delete:
        if request.auth.uid == userId || isAdmin();
    }

    match /wallets/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /transactions/{txId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.buyerId || request.auth.uid == resource.data.sellerId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.buyerId;
    }

    // ============================
    // SPARK ❤️ (Dating)
    // ============================

    match /sparkProfiles/{userId} {
      allow read: if request.auth != null && (resource.data.visibility == "public" || request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /publicProfiles/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /sparkGreetings/{greetingId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromUserId;
      allow read: if request.auth != null && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == resource.data.toUserId || isAdmin());
    }

    match /connections/{connectionId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId || isAdmin());
      allow create, update: if request.auth != null;
    }

    match /relationships/{relId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userA || request.auth.uid == resource.data.userB || isAdmin());
      allow create, update: if request.auth != null;
    }

    /*
     CONVERSATIONS / PRIVATE MESSAGES
    */

    match /conversations/{conversationId} {

      allow read:
        if signedIn()
        &&
        request.auth.uid in resource.data.participants;

      allow create:
        if signedIn()
        &&
        request.auth.uid in request.resource.data.participants;

      allow update:
        if signedIn()
        &&
        request.auth.uid in resource.data.participants;

      allow delete:
        if false;

      match /messages/{messageId} {

        allow read:
          if signedIn()
          &&
          request.auth.uid in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participants;

        allow create:
          if signedIn()
          &&
          request.auth.uid == request.resource.data.senderId
          &&
          request.auth.uid in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participants;

        allow update:
          if signedIn()
          &&
          request.auth.uid == resource.data.senderId;

        allow delete:
          if false;
      }
    }

    /*
     PRODUCTS / MARKETPLACE
    */

    match /products/{productId} {

      allow read:
        if true;

      allow create:
        if signedIn()
        &&
        (
          userRole()=="verified"
          ||
          userRole()=="merchant"
          ||
          isAdmin()
        );

      allow delete:
        if isModerator();
    }

    // ============================
    // COMMUNITIES & IDEAS
    // ============================

    match /communities/{communityId} {

      allow read:
        if signedIn();

      allow create:
        if isMember();

      allow update, delete:
        if signedIn()
        &&
        (
          request.auth.uid == resource.data.ownerId
          ||
          isAdmin()
        );

      /*
       CIRCLE MEMBERSHIP REGISTRY
      */
      match /members/{memberId} {

        allow read:
          if signedIn();

        allow create:
          if signedIn()
          &&
          request.auth.uid == memberId;

        allow update:
          if signedIn()
          &&
          (
            request.auth.uid == memberId || 
            get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
          );

        allow delete:
          if signedIn()
          &&
          get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role == 'owner';
      }

      /*
       CIRCLE COMMUNITY CHAT
      */
      match /messages/{messageId} {
        allow read: 
          if signedIn() 
          && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));

        allow create: 
          if signedIn() 
          && request.resource.data.senderId == request.auth.uid
          && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));

        allow update: 
          if signedIn() 
          && resource.data.senderId == request.auth.uid;

        allow delete: 
          if isAdmin();
      }
    }


    match /communityMessages/{msgId} {

      allow read:
        if signedIn();

      allow create:
        if isMember()
        &&
        request.auth.uid == request.resource.data.authorId;
}


match /communityMedia/{mediaId} {

  allow read:
    if signedIn();

  allow create:
    if isMember()
    &&
    request.auth.uid == request.resource.data.authorId;
}


match /ideaPool/{ideaId} {

  allow read:
    if signedIn();

  allow create:
    if isMember()
    &&
    request.auth.uid == request.resource.data.authorId;
}


// ============================
// COMMERCE & ADS
// ============================

match /shops/{shopId} {

  allow read:
    if signedIn();

  allow create, update:
    if isMember()
    &&
    (
      request.auth.uid == resource.data.ownerId
      ||
      isAdmin()
    );
}


match /ads/{adId} {

  allow read:
    if signedIn()
    &&
    (
      resource.data.status == "approved"
      ||
      request.auth.uid == resource.data.advertiserId
      ||
      isAdmin()
    );


  allow create:
    if isMember()
    &&
    request.auth.uid == request.resource.data.advertiserId;


  allow update, delete:
    if signedIn()
    &&
    (
      request.auth.uid == resource.data.advertiserId
      ||
      isAdmin()
    );
}

    // ============================
    // SYSTEM & MAINTENANCE
    // ============================

    match /siteSettings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    match /publicKeys/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /guestSessions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /securityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false; 
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
