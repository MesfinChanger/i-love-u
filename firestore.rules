
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function hasAcceptedPolicy() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.policyAccepted == true;
    }

    function isParticipant(matchId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Discovery Profiles
    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Matches
    match /matches/{matchId} {
      allow read: if isParticipant(matchId);
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds && hasAcceptedPolicy();
      allow update: if isParticipant(matchId);
      
      match /messages/{messageId} {
        allow read: if isParticipant(matchId);
        allow create: if isParticipant(matchId) && hasAcceptedPolicy();
      }

      match /calls/{callId} {
        allow read, write: if isParticipant(matchId);
        
        match /offerCandidates/{candidateId} {
          allow read, write: if isParticipant(matchId);
        }
        match /answerCandidates/{candidateId} {
          allow read, write: if isParticipant(matchId);
        }
      }
    }

    // Ads
    match /ads/{adId} {
      allow read: if isAuthenticated() && (resource.data.status == 'active' || resource.data.advertiserId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.advertiserId == request.auth.uid || isAdmin());
    }

    // Shops
    match /shops/{shopId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.resource.data.ownerId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }

    // Products
    match /global_products/{productId} {
      allow read: if isAuthenticated();
    }

    // Community
    match /communityMessages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasAcceptedPolicy();
    }
  }
}
