
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /shops/{shopId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;

      match /products/{productId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId;
      }
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      // Participants can only end a match (update status), but cannot delete the match record itself manually
      allow delete: if false; 

      match /messages/{messageId} {
        // Only participants can read the message sub-collection
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
        // Messages are immutable: allow creation but strictly forbid updates or individual deletions
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
