rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- CORE MISSION HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    function hasAcceptedPolicy() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('policyAccepted', false) == true;
    }

    function isMatchParticipant(matchId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
    }

    // --- COLLECTION PROTOCOLS ---

    // User Profiles: Private identity and mission data
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || isOwner(userId);
      allow create, update, delete: if isOwner(userId);
    }

    // Discovery Profiles: Publicly shared snippets (camelCase normalization)
    match /publicProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Matches: Sacred connection spaces
    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds && hasAcceptedPolicy();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      
      match /messages/{messageId} {
        allow read: if isMatchParticipant(matchId);
        allow create: if isMatchParticipant(matchId) && hasAcceptedPolicy();
        allow delete: if isMatchParticipant(matchId) && request.auth.uid == resource.data.senderId;
      }
    }

    // Ads: Community reach campaigns
    match /ads/{adId} {
      allow read, list, get: if true;
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.advertiserId == request.auth.uid || isAdmin());
    }

    // Community Messages: The Global Wall
    match /communityMessages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasAcceptedPolicy();
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
    }

    // Feedback: Direct link to Mission Control
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }
    
    // Config: Platform settings
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
