
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Participant Check Protocol
    function isParticipant(participants) {
      return request.auth.uid in participants;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }

    match /sparkProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    match /conversations/{convId} {
      allow read: if request.auth != null && isParticipant(resource.data.participants);
      allow write: if request.auth != null && isParticipant(request.resource.data.participants);
    }
    
    match /ideaPool/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.authorId;
    }

    match /circles/{circleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.ownerId;
    }

    match /communityMessages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}
