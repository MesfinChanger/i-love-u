rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- SOVEREIGN AUTHORITY HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getSovereignOwnerId() {
      // Reads the one true Guardian from the siteSettings collection
      return exists(/databases/$(database)/documents/siteSettings/sovereignty) 
             ? get(/databases/$(database)/documents/siteSettings/sovereignty).data.ownerId 
             : null;
    }

    function isSovereign() {
      return isAuthenticated() && request.auth.uid == getSovereignOwnerId();
    }

    function isAdmin() {
      // Unified Check: Sovereign Guardian or users with explicitly assigned 'admin' role string
      return isAuthenticated() && (
             isSovereign() || 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member') == 'admin')
      );
    }

    function hasAcceptedPolicy() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('policyAccepted', false) == true;
    }

    // --- COLLECTION PROTOCOLS ---

    // User Profiles: Private identity and mission data
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || isOwner(userId);
      
      // Sovereign Authority Rule: ONLY the Sovereign Guardian can assign permissions/roles
      allow update: if (isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isSeller', 'isAdvertiser', 'sellerStatus', 'advertiserStatus', 'role'])
      )) || isSovereign();
      
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId) || isSovereign();
    }

    // Discovery Profiles: Publicly shared snippets
    match /publicProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isSovereign();
    }

    // Idea Pool: The Global Knowledge Swimming Pool
    match /ideaPool/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasAcceptedPolicy() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    // Site Settings: Administrative configurations
    match /siteSettings/{docId} {
      allow read: if true;
      // Sovereignty document can be created IF it doesn't exist (VACANCY check)
      allow create: if docId == 'sovereignty' && !exists(/databases/$(database)/documents/siteSettings/sovereignty);
      // ONLY the current sovereign can delegate or change authority
      allow update: if isSovereign() || (docId == 'sovereignty' && !exists(/databases/$(database)/documents/siteSettings/sovereignty));
      allow delete: if false;
    }

    // Matches: Sacred connection spaces
    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds && hasAcceptedPolicy();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds && hasAcceptedPolicy();
        allow delete: if (isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds && (request.auth.uid == resource.data.senderId || isAdmin()));
      }
    }

    // Ads: Community reach campaigns
    match /ads/{adId} {
      allow read, list, get: if true;
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid;
      allow update: if isAuthenticated() && (request.resource.data.advertiserId == request.auth.uid || isAdmin());
    }

    // Feedback: Direct link to Mission Control
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }
    
    // Config: Platform settings
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Transactions: Mission financial records
    match /transactions/{transactionId} {
      allow create: if false; // System only (via Admin SDK)
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update, delete: if false;
    }
  }
}