rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- CORE MISSION HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    function hasAcceptedPolicy() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('policyAccepted', false) == true;
    }

    function isMatchParticipant(matchId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
    }

    // --- COLLECTION PROTOCOLS ---

    // User Profiles: Private identity and mission data
    match /users/{userId} {
      // Allow any authenticated heart to 'get' a profile snippet for matches/discovery
      allow get: if isAuthenticated();
      // Only admins or the owner can 'list' (query) the private users collection
      allow list: if isAdmin() || isOwner(userId);
      // Standard owner-only write permissions
      allow create, update, delete: if isOwner(userId);
    }

    // Discovery Profiles: Publicly shared snippets for carousel (Normalized to camelCase)
    match /publicProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Matches: Sacred connection spaces
    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.userIds && hasAcceptedPolicy();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.userIds;
      
      match /messages/{messageId} {
        allow read: if isMatchParticipant(matchId);
        allow create: if isMatchParticipant(matchId) && hasAcceptedPolicy();
        allow delete: if isMatchParticipant(matchId) && request.auth.uid == resource.data.senderId;
      }

      match /calls/{callId} {
        allow read, write: if isMatchParticipant(matchId);
        
        match /offerCandidates/{candidateId} {
          allow read, write: if isMatchParticipant(matchId);
        }
        match /answerCandidates/{candidateId} {
          allow read, write: if isMatchParticipant(matchId);
        }
      }
    }

    // Ads: Community reach campaigns
    match /ads/{adId} {
      // Grant explicit public read for Discover feed and Sponsored sparks
      allow read, list, get: if true;
      allow create: if isAuthenticated() && request.resource.data.advertiserId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.advertiserId == request.auth.uid || isAdmin());
    }

    // Shops: Global artisan storefronts
    match /shops/{shopId} {
      allow read: if true;
      allow write: if isAuthenticated() && (request.resource.data.ownerId == request.auth.uid || resource.data.ownerId == request.auth.uid);
    }

    // Products: Global inventory
    match /global_products/{productId} {
      allow read: if true;
    }

    // Community Messages: The Global Wall
    match /communityMessages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasAcceptedPolicy();
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
    }

    // Feedback: Direct link to Mission Control
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }
    
    // Config: Platform settings (e.g. pricing)
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
