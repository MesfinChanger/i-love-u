rules_version = '2';

service firebase.storage {

  match /b/{bucket}/o {


    /*
    PUBLIC IMAGES
    Example:
    - hero images
    - approved public content
    */

    match /hero-images/{fileName} {

      allow read:
        if true;

      allow write:
        if request.auth != null
        &&
        request.auth.token.email == "thearmyoj@gmail.com";
    }



    /*
    USER PROFILE MEDIA
    */

    match /users/{userId}/{allPaths=**} {

      allow read:
        if true;

      allow write:
        if request.auth != null
        &&
        request.auth.uid == userId;
    }



    /*
    CHAT ATTACHMENTS
    PRIVATE MEDIA
    */

    match /conversations/{conversationId}/{allPaths=**} {

      allow read, write:
        if request.auth != null;
    }



    /*
    DEFAULT DENY
    */

    match /{allPaths=**} {

      allow read, write:
        if false;
    }

  }
}