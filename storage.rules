rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Testing Protocol: Full permissive access for initial verification.
      // Final production rule: allow read; allow write: if request.auth != null;
      allow read, write: if true;
    }

    match /hero-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}