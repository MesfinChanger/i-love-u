rules_version = '2';

service firebase.storage {

  match /b/{bucket}/o {


    /*
    PUBLIC HERO CONTENT
    */

    match /hero-images/{fileName} {

      allow read:
        if true;

      allow write:
        if request.auth != null
        &&
        request.auth.token.email == "thearmyoj@gmail.com";
    }



    /*
    USER MEDIA
    */

    match /users/{userId}/{allPaths=**} {

      allow read:
        if request.auth != null;

      allow write:
        if request.auth != null
        &&
        request.auth.uid == userId;
    }



    /*
    PRIVATE CHAT MEDIA
    */

    match /conversations/{conversationId}/{userId}/{allPaths=**} {

      allow read, write:
        if request.auth != null
        &&
        request.auth.uid == userId;
    }



    /*
    EVERYTHING ELSE DENIED
    */

    match /{allPaths=**} {

      allow read, write:
        if false;
    }

  }
}