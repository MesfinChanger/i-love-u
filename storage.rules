rules_version = '2';

service firebase.storage {

  match /b/{bucket}/o {

    /*
    ==========================
    PUBLIC HERO / PLATFORM IMAGES
    ==========================
    */

    match /hero-images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "thearmyoj@gmail.com";
    }

    /*
    ==========================
    USER PROFILE IMAGES
    ==========================
    */

    match /profiles/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    /*
    ==========================
    PRIVATE CHAT MEDIA
    ==========================
    */

    match /chat/{conversationId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    /*
    ==========================
    COMMUNITY MEDIA
    ==========================
    */

    match /community/{communityId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /*
    ==========================
    DEFAULT BLOCK
    ==========================
    */

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
